---
import IconArrowUp from '@/icons/IconArrowUp.astro';
import IconGitHub from '@/icons/IconGitHub.astro';

export interface Tag {
  label: string;
  Icon: (_props: { class?: string }) => any;
  color?: string;
}

export interface GalleryImage {
  image: string;
  alt: string;
}

export interface Props {
  title: string;
  description: string;
  url: string;
  githubUrl?: string;
  previewImage: string;
  gallery?: GalleryImage[];
  tags: Tag[];
  details: string;
  accentColor: 'blue' | 'teal' | 'red' | 'purple';
}

const { title, description, url, githubUrl, previewImage, gallery = [], tags, accentColor, details } = Astro.props;

const tagBg = {
  blue:   'bg-sky-400/[0.07] border-sky-400/20 hover:bg-sky-400/15',
  teal:   'bg-emerald-400/[0.07] border-emerald-400/20 hover:bg-emerald-400/15',
  red:    'bg-orange-400/[0.07] border-orange-400/20 hover:bg-orange-400/15',
  purple: 'bg-violet-400/[0.07] border-violet-400/20 hover:bg-violet-400/15',
}[accentColor];

const borderAccent = {
  blue:   'via-sky-400/50',
  teal:   'via-emerald-400/50',
  red:    'via-orange-400/50',
  purple: 'via-violet-400/50',
}[accentColor];

const verMasColor = {
  blue:   'text-sky-400 border-sky-400/40 bg-sky-400/10 hover:bg-sky-400/20',
  teal:   'text-emerald-400 border-emerald-400/40 bg-emerald-400/10 hover:bg-emerald-400/20',
  red:    'text-orange-400 border-orange-400/40 bg-orange-400/10 hover:bg-orange-400/20',
  purple: 'text-violet-400 border-violet-400/40 bg-violet-400/10 hover:bg-violet-400/20',
}[accentColor];

const titleAccent = {
  blue:   'text-sky-400',
  teal:   'text-emerald-400',
  red:    'text-orange-400',
  purple: 'text-violet-400',
}[accentColor];

const cardBorder = {
  blue:   'border-sky-400/30 shadow-sky-500/10',
  teal:   'border-emerald-400/30 shadow-emerald-500/10',
  red:    'border-orange-400/30 shadow-orange-500/10',
  purple: 'border-violet-400/30 shadow-violet-500/10',
}[accentColor];

const galleryRing = {
  blue:   'ring-sky-400/40',
  teal:   'ring-emerald-400/40',
  red:    'ring-orange-400/40',
  purple: 'ring-violet-400/40',
}[accentColor];

// Unique id para el lightbox de esta card
const cardId = `card-${Math.random().toString(36).slice(2, 7)}`;
---

<div class="flip-card" role="region" aria-label={title} id={cardId}>
  <div class="flip-inner">

    <!-- ── FRONT ── -->
    <div class="flip-face flip-front rounded-xl border shadow-lg shadow-slate-950 border-white/[0.07] bg-[#0f1623] overflow-hidden hover:animate-pulse duration-[3000ms]">

      <div class="relative overflow-hidden h-56 lg:h-72 bg-[#131929] shrink-0">
        <img
          src={previewImage}
          alt={title}
          loading="lazy"
          class="w-full h-full object-cover object-top"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#0f1623]/90 via-[#0f1623]/10 to-transparent" />
      </div>

      <div class="flex flex-col gap-4 p-6">

        <div class="flex items-center justify-between gap-2">
          <h3 class="text-base font-semibold text-white/90 tracking-tight">{title}</h3>
          {githubUrl && (
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1.5 text-[0.65rem] font-mono px-4 py-1.5 rounded-lg border border-white/[0.08] bg-white/[0.03] text-slate-400 hover:text-white hover:border-white/20 transition-all duration-200 shrink-0"
            >
              <IconGitHub class="w-5 h-5" />
              GitHub
            </a>
          )}
        </div>

        <p class="text-sm text-slate-500 leading-relaxed line-clamp-2">{description}</p>

        <div class="flex flex-wrap gap-2">
          {tags.map(({ label, Icon, color = 'text-slate-400' }) => (
            <span class={`flex items-center gap-1.5 text-[0.62rem] font-mono px-2.5 py-1 rounded-md border cursor-default transition-colors duration-200 ${tagBg} text-slate-300`}>
              <Icon class={`w-3.5 h-3.5 shrink-0 ${color}`} />
              {label}
            </span>
          ))}
        </div>

        <div class="flex items-center gap-3 pt-2 border-t border-white/[0.05]">
          <button
            onclick="this.closest('.flip-card').classList.add('is-flipped')"
            class={`flex items-center gap-1.5 text-[0.8rem] font-mono px-4 py-1.5 rounded-lg border transition-all duration-200 ${verMasColor}`}
          >
            <IconArrowUp class="w-5 h-5" />
            Acerca del proyecto
          </button>
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 text-[0.8rem] font-mono px-4 py-1.5 rounded-lg border border-white/[0.08] bg-white/[0.03] text-slate-400 hover:text-white hover:border-white/20 transition-all duration-200"
          >
            <IconArrowUp class="w-5 h-5" />
            Visitar el sitio web
          </a>
        </div>
      </div>

      <div class={`absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent ${borderAccent} to-transparent`} />
    </div>

    <!-- ── BACK ── -->
    <div class={`flip-face flip-back rounded-xl border bg-[#0d1220] overflow-hidden flex flex-col ${cardBorder}`}>

      <div class={`h-1 w-full bg-gradient-to-r from-transparent ${borderAccent} to-transparent shrink-0`} />

      <div class="flex flex-col gap-4 p-6 flex-1">

        <div>
          <p class="font-mono text-[0.58rem] tracking-widest uppercase text-slate-600 mb-1">Proyecto</p>
          <h3 class={`text-lg font-bold tracking-tight ${titleAccent}`}>{title}</h3>
        </div>

        <div>
          <p class="font-mono text-[0.58rem] tracking-widest uppercase text-slate-600 mb-1">Te cuento sobre el proyecto</p>
          <p class="text-sm text-slate-300 leading-relaxed">{details}</p>
        </div>

        <!-- Tech stack -->
        <div>
          <p class="font-mono text-[0.58rem] tracking-widest uppercase text-slate-600 mb-2">Tecnologías</p>
          <div class="flex flex-wrap gap-2">
            {tags.map(({ label, Icon, color = 'text-slate-400' }) => (
              <span class={`flex items-center gap-1.5 text-[0.62rem] font-mono px-2.5 py-1 rounded-md border cursor-default transition-colors duration-200 ${tagBg} text-slate-300`}>
                <Icon class={`w-3.5 h-3.5 shrink-0 ${color}`} />
                {label}
              </span>
            ))}
          </div>
        </div>

        <div class="flex-1" />

        <div class="flex items-center gap-3 pt-3 border-t border-white/[0.06]">
          
          <button
            onclick="this.closest('.flip-card').classList.remove('is-flipped')"
            class="flex items-center gap-1.5 text-[0.8rem] font-mono px-4 py-1.5 rounded-lg border border-white/[0.08] bg-white/[0.03] text-slate-400 hover:text-white hover:border-white/20 transition-all duration-200"
          >
            <IconArrowUp class="w-5 h-5" />
            Volver
          </button>

          {githubUrl && (
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1.5 text-[0.65rem] font-mono px-4 py-1.5 rounded-lg border border-white/[0.08] bg-white/[0.03] text-slate-400 hover:text-white hover:border-white/20 transition-all duration-200"
            >
              <IconGitHub class="w-5 h-5" />
              GitHub
            </a>
          )}

          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class={`ml-auto flex items-center gap-1.5 text-[0.65rem] font-mono px-4 py-1.5 rounded-lg border transition-all duration-200 ${verMasColor}`}
          >
            <IconArrowUp class="w-5 h-5" />
            Visitar el sitio web
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .flip-card {
    perspective: 1200px;
    height: 100%;
    min-height: 520px;      
  }
  .flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .flip-card.is-flipped .flip-inner {
    transform: rotateY(180deg);
  }
  .flip-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    display: flex;
    flex-direction: column;
  }
  .flip-back {
    transform: rotateY(180deg);
    overflow: hidden;
  }
  .lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }
</style>

