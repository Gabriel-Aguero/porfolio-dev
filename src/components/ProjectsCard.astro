---
import IconGitHub from "@/icons/IconGitHub.astro";

export interface Tag {
  label: string;
  Icon: (_props: { class?: string }) => any;
  color?: string;
}

export interface Props {
  title: string;
  description: string;
  url: string;
  githubUrl?: string;
  previewImage: string;
  tags: Tag[];
  accentColor: 'blue' | 'teal' | 'red' | 'purple';
}

const { title, description, url, githubUrl, previewImage, tags, accentColor } = Astro.props;

const accent = {
  blue:   'hover:border-sky-400/25 hover:shadow-sky-500/[0.08]',
  teal:   'hover:border-emerald-400/25 hover:shadow-emerald-500/[0.08]',
  red: 'hover:border-orange-400/25 hover:shadow-orange-500/[0.08]',
  purple: 'hover:border-violet-400/25 hover:shadow-violet-500/[0.08]',
}[accentColor];

const tagBg = {
  blue:   'bg-sky-400/[0.07] border-sky-400/20',
  teal:   'bg-emerald-400/[0.07] border-emerald-400/20',
  red: 'bg-red-400/[0.07] border-red-400/20',
  purple: 'bg-violet-400/[0.07] border-violet-400/20',
}[accentColor];

const borderAccent = {
  blue:   'via-sky-400/50',
  teal:   'via-emerald-400/50',
  red: 'via-red-400/50',
  purple: 'via-violet-400/50',
}[accentColor];

const glowBg = {
  blue:   'group-hover:opacity-100 from-sky-500/[0.4]',
  teal:   'group-hover:opacity-100 from-emerald-500/[0.04]',
  red: 'group-hover:opacity-100 from-red-500/[0.04]',
  purple: 'group-hover:opacity-100 from-violet-500/[0.04]',
}[accentColor];

const visitColor = {
  blue:   'text-sky-400 border-sky-400/30 bg-sky-400/10',
  teal:   'text-emerald-400 border-emerald-400/30 bg-emerald-400/10',
  red: 'text-red-400 border-red-400/30 bg-red-400/10',
  purple: 'text-violet-400 border-violet-400/30 bg-violet-400/10',
}[accentColor];
---

<div
  class={`group relative flex flex-col rounded-xl border border-white/[0.07] bg-[#0f1623] overflow-hidden
    transition-[transform,box-shadow,border-color] duration-500 hover:animate-pulsing`}
>

  <!-- Subtle color wash on hover -->
  <div class={`absolute inset-0 opacity-0 transition-opacity duration-500 bg-gradient-to-b to-transparent pointer-events-none z-0 ${glowBg}`} />

  <!-- Image -->
  <div class="relative overflow-hidden h-52 bg-[#131929] shrink-0 z-[1]">
    <img
      src={previewImage}
      alt={title}
      loading="lazy"
      class="w-full h-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-[1.03]"
    />

    <!-- bottom fade -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#0f1623]/90 via-[#0f1623]/20 to-transparent" />    

    <!-- Links -->
    <div class="absolute bottom-3 right-3 flex items-center gap-2 z-10">
      <!-- {githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          onclick="event.stopPropagation()"
          class="flex items-center gap-1.5 text-[0.6rem] font-mono text-slate-400 bg-black/50 backdrop-blur-sm px-2.5 py-1 rounded-full border border-white/[0.08]
            hover:text-white hover:border-white/20 transition-all duration-300"
        >
          <IconGitHub class="w-3 h-3" />
          GitHub
        </a>
      )} -->
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class={`flex items-center gap-1.5 text-[0.6rem] font-mono bg-black/50 backdrop-blur-sm px-2.5 py-1 rounded-full border
          hover:brightness-110 transition-all duration-300 ${visitColor}`}
      >
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17L17 7M17 7H7M17 7V17"/>
        </svg>
        Ver proyecto
      </a>
    </div>
  </div>

  <!-- Content -->
  <div class="relative flex flex-col gap-3 p-5 z-[1]">
    <div class="flex items-center justify-between">    
    <h3 class="text-base font-semibold text-white/85 tracking-tight transition-colors duration-300 group-hover:text-white">
      {title}                        
    </h3>
    <span>
      { githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          onclick="event.stopPropagation()"
          class="flex items-center gap-1.5 text-[0.6rem] font-mono text-slate-400 bg-black/50 backdrop-blur-sm px-2.5 py-1 rounded-full border border-white/[0.08]
            hover:text-white hover:border-white/20 transition-all duration-300"
        >
          <IconGitHub class="w-3 h-3" />
          GitHub
        </a>
      )}
    </span>
    </div>
    <p class="text-sm text-slate-500 leading-relaxed transition-colors duration-300 group-hover:text-slate-400">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 pt-1">
      {tags.map(({ label, Icon, color = 'text-slate-400' }) => (
        <span class={`flex items-center gap-1.5 text-[0.62rem] font-mono px-2.5 py-1 rounded-md border transition-colors duration-300 ${tagBg} text-slate-400 group-hover:text-slate-300`}>
          <Icon class={`w-3.5 h-3.5 shrink-0 ${color}`} />
          {label}
        </span>
      ))}
    </div>

    <!-- URL -->
    <span class="text-[0.58rem] font-mono text-slate-700 truncate mt-0.5 transition-colors duration-300 group-hover:text-slate-500">
      {url.replace('https://', '').replace('http://', '')}
    </span>
  </div>

  <!-- Bottom accent line -->
  <div class={`absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent ${borderAccent} to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-700 ease-out`} />
</div>