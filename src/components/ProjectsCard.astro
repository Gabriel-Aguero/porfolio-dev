---
export interface Tag {
  label: string;
  Icon: (_props: { class?: string }) => any;
}

export interface Props {
  title: string;
  description: string;
  url: string;
  previewImage: string;
  tags: Tag[];
  accentColor: 'blue' | 'teal' | 'orange' | 'purple';
}

const { title, description, url, previewImage, tags, accentColor } = Astro.props;

const accent = {
  blue:   'group-hover:border-sky-400/40 group-hover:shadow-sky-500/20 group-hover:shadow-lg',
  teal:   'group-hover:border-emerald-400/40 group-hover:shadow-emerald-500/20 group-hover:shadow-lg',
  orange: 'group-hover:border-orange-400/40 group-hover:shadow-orange-500/20 group-hover:shadow-lg',
  purple: 'group-hover:border-violet-400/40 group-hover:shadow-violet-500/20 group-hover:shadow-lg',
}[accentColor];

const tagColor = {
  blue:   'bg-sky-400/10 text-sky-300 group-hover:bg-sky-400/20',
  teal:   'bg-emerald-400/10 text-emerald-300 group-hover:bg-emerald-400/20',
  orange: 'bg-orange-400/10 text-orange-300 group-hover:bg-orange-400/20',
  purple: 'bg-violet-400/10 text-violet-300 group-hover:bg-violet-400/20',
}[accentColor];

const borderAccent = {
  blue:   'via-sky-400/50',
  teal:   'via-emerald-400/50',
  orange: 'via-orange-400/50',
  purple: 'via-violet-400/50',
}[accentColor];
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class={`group relative flex flex-col rounded-xl border border-white/[0.08] bg-[#0f1623] overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl ${accent}`}
>
  <!-- Animated gradient border on hover -->
  <div class={`absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-r from-transparent ${borderAccent} to-transparent`} />
  
  <!-- Image container with overlay -->
  <div class="relative overflow-hidden h-48 bg-[#131929]">
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#0f1623] via-transparent to-transparent opacity-0 group-hover:opacity-60 transition-opacity duration-500 z-10" />
    
    <img
      src={previewImage}
      alt={title}
      loading="lazy"
      class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110"
    />
    
    <!-- View project indicator -->
    <div class="absolute bottom-3 right-3 z-20 translate-y-10 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
      <div class={`flex items-center gap-1 text-xs font-mono ${tagColor.split(' ')[1]} bg-black/60 backdrop-blur-sm px-3 py-1.5 rounded-full border border-white/10`}>
        <span>Ver proyecto</span>
        
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="relative flex flex-col gap-3 p-5 z-10">
    <!-- Live indicator (opcional - puedes quitarlo si no lo necesitas) -->
    <div class="flex items-center gap-2 absolute -top-3 right-5">
      <div class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400/60"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </div>
      <span class="text-[0.6rem] font-mono text-emerald-400/80">live</span>
    </div>

    <h3 class="text-base font-semibold text-white/90 tracking-tight group-hover:text-white transition-colors">
      {title}
    </h3>
    
    <p class="text-sm text-slate-400 leading-relaxed group-hover:text-slate-300 transition-colors">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 pt-2">
      {tags.map(({ label, Icon }) => (        
        <span class={`text-[0.65rem] flex items-center justify-center font-mono px-6 py-1 transition-all duration-300 ${tagColor} border border-white/5 hover:scale-105`}>
          <Icon />
          <span class="ml-1">{label}</span>
        </span>        
      ))}
    </div>

    <!-- URL subtle hint (opcional) -->
    <div class="flex items-center gap-1 mt-1 text-[0.6rem] font-mono text-slate-600 group-hover:text-slate-500 transition-colors">     
      <span class="truncate max-w-[150px]">{url.replace('https://', '')}</span>
    </div>
  </div>

  <!-- Bottom accent line -->
  <div class={`absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent ${borderAccent} to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-500`} />
</a>