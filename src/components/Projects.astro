---
import ProjectCard from './ProjectsCard.astro';

import IconAstro    from '@/icons/IconAstro.astro';
import IconReact    from '@/icons/IconReact.astro';
import IconTailwind from '@/icons/IconTailwind.astro';
import IconSupabase from '@/icons/IconSupabase.astro';
import IconMercadoPago from '@/icons/IconMercadoPago.astro';
/**
 * color: clase Tailwind del color original de cada tecnología.
 * githubUrl: opcional, si el repo es público.
 */
const projects = [
  {
    title: 'Liga Santander',
    description: 'Sitio Web Oficial de la Liga Santander, una liga de fútbol amateur en argentina. Perfil para clubes, fichajes de jugadores, fixtures, tabla de posiciones y resultados en tiempo real.',
    url: 'https://www.liga-s-argentina.com.ar/',    
    previewImage: '/images/liga-santander.webp',
    accentColor: 'red' as const,
    tags: [
      { label: 'Astro',       Icon: IconAstro,    color: 'text-orange-400'  },
      { label: 'React',       Icon: IconReact,    color: 'text-sky-400'     },
      { label: 'Tailwindcss', Icon: IconTailwind, color: 'text-cyan-400'    },
      { label: 'Supabase',    Icon: IconSupabase, color: 'text-emerald-400' },
      
    ],
    details: 'La Liga Santander es una liga de fútbol amateur en argentina con mas de 50 clubes. Cuenta con perfil para clubes y administradores. Cada club tiene la posibilidad de registrar jugadores, gestionar la información de su club e imprimir la lista de buena fe. Para todo publico esta disponible fixtures, tabla de posiciones y resultados de todas las jornadas.',
  },
  {
    title: 'Escalas de Sedoanalgesia',
    description: 'Herramienta clínica con escalas de evaluación de dolor y sedación para profesionales de la salud.',
    url: 'https://escalasanalgosedacion.com/',
    githubUrl: 'https://github.com/Gabriel-Aguero/analgosedacionApp.git',
    previewImage: '/images/escalasedoanalgesia.webp',
    accentColor: 'blue' as const,
    tags: [
      { label: 'Astro',       Icon: IconAstro,    color: 'text-orange-400'  },
      { label: 'React',       Icon: IconReact,    color: 'text-sky-400'     },
      { label: 'Tailwindcss', Icon: IconTailwind, color: 'text-cyan-400'    },
      { label: 'Supabase',    Icon: IconSupabase, color: 'text-emerald-400' },
     
    ],
    details: 'Esta es una aplicación que esta basada en un proyecto de investigación, con el objetivo centrado en mejorar la calidad del cuidado de pacientes. Cuenta con diferentes escalas y calclula el Score teniendo en cuenta ciertos criterios y condiciones del paciente.',
  },
  {
    title: 'Pagos Clubes',
    description: 'Sistema de gestión de cuotas y cobros digitales para clubes deportivos.',
    url: 'https://pagosclubes.com',
    githubUrl: 'https://github.com/Gabriel-Aguero/sistema_gestor.git',
    previewImage: '/images/pagosclubes.webp',
    accentColor: 'teal' as const,
    tags: [      
      { label: 'React',       Icon: IconReact,    color: 'text-sky-400'     },
      { label: 'Tailwindcss', Icon: IconTailwind, color: 'text-cyan-400'    },
      { label: 'Supabase',    Icon: IconSupabase, color: 'text-emerald-400' },
      { label: 'MercadoPago', Icon: IconMercadoPago, color: 'text-sky-400'     },
      
    ],
    details: 'Esta aplicación permite gestionar y llevar el control cuotas. Cuenta con un perfil para el administrador y tambien la posibilidad de realizar pagos por parte de clientes a traves de mercado pago. El administrador puede llevar el control de clientes y el estado de cuenta de cada uno de ellos. Meses atrasado, fecha de pagos, proximo vencimiento.',
  },
  {
    title: 'Fundación Silvia Flores',
    description: 'Sitio institucional para una fundación sin fines de lucro con historia, actividades y contacto.',
    url: 'https://www.fundacionsilviaflores.org.ar/',
    githubUrl: 'https://github.com/Gabriel-Aguero/fundacionsilflo.git',
    previewImage: '/images/fundacion.webp',
    accentColor: 'blue' as const,
    tags: [
      { label: 'Astro',       Icon: IconAstro,    color: 'text-orange-400'  },
      { label: 'React',       Icon: IconReact,    color: 'text-sky-400'     },
      { label: 'Tailwindcss', Icon: IconTailwind, color: 'text-cyan-400'    },
      { label: 'Supabase',    Icon: IconSupabase, color: 'text-emerald-400' },
      
    ],
    details: 'Este sitio es una página web para una fundación sin fines de lucro la cual tiene como objetivo ayudar a personas con bajos recursos acceder a cursos y capacitaciones de manera gratuita. Brinda una gran espacio con profesionales de la salud que dan oportunidades a las personas',
  },
];
---

<section id="proyectos" class="max-w-5xl mx-auto px-4 py-20">

  <div class="mb-12">    
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-orange-300">
      Mis <span class="text-sky-400">Proyectos</span>
    </h2>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    {projects.map((project) => (
      <ProjectCard {...project} />
    ))}
  </div>

</section>