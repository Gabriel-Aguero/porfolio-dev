---
import IconAstro    from '@/icons/IconAstro.astro';
import IconReact    from '@/icons/IconReact.astro';
import IconTailwind from '@/icons/IconTailwind.astro';
import IconSupabase from '@/icons/IconSupabase.astro';
import IconNode     from '@/icons/IconNodeJs.astro';
import IconHTML     from '@/icons/IconHTML.astro';
import IconCSS      from '@/icons/IconCss.astro';
import IconJS       from '@/icons/IconJavaScript.astro';
import IconGithub   from '@/icons/IconGitHub.astro';

const techs = [
  { label: 'Astro',      Icon: IconAstro,    iconClass: 'text-orange-400', glow: 'rgba(249,115,22,0.35)',  border: 'rgba(249,115,22,0.6)'  },
  { label: 'React',      Icon: IconReact,    iconClass: 'text-sky-400',    glow: 'rgba(56,189,248,0.35)',  border: 'rgba(56,189,248,0.6)'  },
  { label: 'Tailwind',   Icon: IconTailwind, iconClass: 'text-cyan-400',   glow: 'rgba(34,211,238,0.35)',  border: 'rgba(34,211,238,0.6)'  },
  { label: 'Supabase',   Icon: IconSupabase, iconClass: 'text-emerald-400',glow: 'rgba(52,211,153,0.35)',  border: 'rgba(52,211,153,0.6)'  },
  { label: 'Node.js',    Icon: IconNode,     iconClass: 'text-green-400',  glow: 'rgba(74,222,128,0.35)',  border: 'rgba(74,222,128,0.6)'  },
  { label: 'HTML',       Icon: IconHTML,     iconClass: 'text-orange-500', glow: 'rgba(226,131,74,0.35)',  border: 'rgba(226,131,74,0.6)'  },
  { label: 'CSS',        Icon: IconCSS,      iconClass: 'text-blue-400',   glow: 'rgba(59,130,246,0.35)',  border: 'rgba(59,130,246,0.6)'  },
  { label: 'JavaScript', Icon: IconJS,       iconClass: 'text-yellow-400', glow: 'rgba(250,204,21,0.35)',  border: 'rgba(250,204,21,0.6)'  },
  { label: 'GitHub',     Icon: IconGithub,   iconClass: 'text-violet-400', glow: 'rgba(167,139,250,0.35)', border: 'rgba(167,139,250,0.6)' },
];

const techsRow2 = [...techs].reverse();
---

<section class="max-w-6xl mx-auto py-12">
  <!-- Header -->
  <div class="flex flex-col items-center gap-3 mb-10">
    <div class="flex items-center gap-3">
      <span class="inline-block w-6 h-px bg-sky-400" />
      <span class="font-mono text-[1rem] tracking-[0.2em] uppercase text-sky-400">Mi stack tecnológico</span>
      <span class="inline-block w-6 h-px bg-sky-400" />
    </div>
    <!-- <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-white">Tecnologías que uso</h2>    -->
  </div>

  <!-- Marquee wrapper -->
  <div class="relative overflow-hidden py-2">
    <!-- fade edges -->
    <div class="pointer-events-none absolute left-0 top-0 bottom-0 w-24 z-10"
         style="background: linear-gradient(to right, #0b0f1a, transparent)"></div>
    <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-24 z-10"
         style="background: linear-gradient(to left, #0b0f1a, transparent)"></div>

    <!-- Row 1 — izquierda -->
    <div class="marquee-row mb-3">
      <div class="marquee-track track-left flex gap-3" style="width: max-content">
        {[...techs, ...techs].map(({ label, Icon, iconClass, glow, border }) => (
          <div
            class="tech-pill group flex items-center gap-2.5 px-4 py-2 rounded-full border border-white/[0.07] bg-[#111827] cursor-default select-none transition-all duration-300 hover:border-[var(--b)] hover:shadow-[0_0_18px_var(--g)] hover:-translate-y-0.5"
            style={`--g: ${glow}; --b: ${border}`}
          >
            <Icon class={`w-4 h-4 shrink-0 transition-transform duration-300 group-hover:scale-110 ${iconClass}`} />
            <span class="font-mono text-[0.7rem] text-slate-400 group-hover:text-slate-200 transition-colors duration-300 whitespace-nowrap">
              {label}
            </span>
          </div>
        ))}
      </div>
    </div>

    <!-- Row 2 — derecha -->
    <div class="marquee-row">
      <div class="marquee-track track-right flex gap-3" style="width: max-content">
        {[...techsRow2, ...techsRow2].map(({ label, Icon, iconClass, glow, border }) => (
          <div
            class="tech-pill group flex items-center gap-2.5 px-4 py-2 rounded-full border border-white/[0.07] bg-[#111827] cursor-default select-none transition-all duration-300 hover:border-[var(--b)] hover:shadow-[0_0_18px_var(--g)] hover:-translate-y-0.5"
            style={`--g: ${glow}; --b: ${border}`}
          >
            <Icon class={`w-4 h-4 shrink-0 transition-transform duration-300 group-hover:scale-110 ${iconClass}`} />
            <span class="font-mono text-[0.7rem] text-slate-400 group-hover:text-slate-200 transition-colors duration-300 whitespace-nowrap">
              {label}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .track-left {
    animation: scroll-left 25s linear infinite;
  }
  .track-right {
    animation: scroll-right 30s linear infinite;
  }

  .marquee-row:hover .marquee-track {
    animation-play-state: paused;
  }

  @keyframes scroll-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes scroll-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }
</style>