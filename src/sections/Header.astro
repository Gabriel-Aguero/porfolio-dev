---
import ChevronLeft from "@/icons/chevronLeft.astro";
import ChevronRigth from "@/icons/chevronRigth.astro";
import Close from "@/icons/close.astro";
import Logo from "@/icons/dev.astro";
import IconCoffe from "@/icons/IconCoffe.astro";
import Menu from "@/icons/menu.astro";
---

<!-- Arranca transparente, al hacer scroll gana fondo + blur -->
<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 w-full py-4 px-4 md:px-8 text-white border-b border-transparent bg-black md:bg-transparent transition-all duration-500"
>
  <div class="max-w-6xl mx-auto">
    <div class="flex justify-between items-center">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-2xl font-bold">
        <ChevronLeft class="text-blue-500 w-10 h-10" />
        <span class="sm:inline">Gabydev</span>
        <ChevronRigth class="text-blue-500 w-10 h-10" />
      </a>

      <!-- Botón menú (solo mobile) -->
      <button
        id="toggle-menu"
        class="md:hidden p-2 text-slate-300 relative z-50"
        aria-label="Abrir menú"
      >
        <Menu class="w-7 h-7" />
      </button>

      <button
        id="toggle-close-menu"
        class="hidden p-2 text-slate-300 relative z-50"
        aria-label="Cerrar menú"
      >
        <Close class="w-7 h-7" />
      </button>

      <!-- Navegación -->
      <nav
        id="menu"
        class="hidden md:flex flex-col md:flex-row fixed md:static top-0 left-0 w-full md:w-auto h-screen md:h-auto bg-black/40 md:bg-transparent backdrop-blur-lg md:backdrop-blur-none items-center justify-center md:justify-end gap-8 md:gap-10 text-lg transition-all duration-300 z-40"
      >
       <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-2xl font-bold md:hidden">
        <ChevronLeft class="text-blue-500 w-10 h-10" />
        <span class="sm:inline">Gabydev</span>
        <ChevronRigth class="text-blue-500 w-10 h-10" />
      </a>

        <ul class="flex flex-col items-center justify-center md:flex-row gap-8 md:gap-10 text-xl cursor-pointer">
          <li>
            <a href="/" class="group relative text-white hover:text-sky-400 transition-colors duration-300">
              Inicio
              <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-amber-500 transition-all duration-300 group-hover:w-full"></span>
            </a>
          </li>
          <li>
            <a href="/#hero" class="group relative text-white hover:text-sky-400 transition-colors duration-300">
              Sobre mí
              <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-amber-500 transition-all duration-300 group-hover:w-full"></span>
            </a>
          </li>
          <li>
            <a href="/#proyectos" class="group relative text-white hover:text-sky-400 transition-colors duration-300">
              Proyectos
              <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-amber-500 transition-all duration-300 group-hover:w-full"></span>
            </a>
          </li>
          <li>
            <a href="/#contacto" class="group relative text-white hover:text-sky-400 transition-colors duration-300">
              Contacto
              <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-amber-500 transition-all duration-300 group-hover:w-full"></span>
            </a>
          </li>
          <li>
            <a href="/#footer" class="group relative text-white hover:text-sky-400 transition-colors duration-300">
              <IconCoffe class="w-7 h-7" />
              <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-amber-500 transition-all duration-300 group-hover:w-full"></span>
            </a>
          </li>
        </ul>
      </nav>

    </div>
  </div>
</header>

<div class="h-[73px]"></div>

<script>
  const header = document.getElementById("main-header");
  const toggle = document.getElementById("toggle-menu");
  const closeToggle = document.getElementById("toggle-close-menu");
  const menu = document.getElementById("menu");

  // Scroll: agrega fondo + blur al bajar de 20px
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      header?.classList.add("md:bg-[#0b0f1a]/70", "md:backdrop-blur-md", "md:border-white/[0.06]");
      header?.classList.remove("bg-transparent", "border-transparent");
    } else {
      header?.classList.remove("md:bg-[#0b0f1a]/70", "md:backdrop-blur-md", "md:border-white/[0.06]");
      header?.classList.add("bg-transparent", "border-transparent");
    }
  }, { passive: true });

  // Menú mobile
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menu?.classList.toggle("flex");
    toggle?.classList.toggle("hidden");
    closeToggle?.classList.toggle("hidden");
  });

  closeToggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menu?.classList.toggle("flex");
    toggle?.classList.toggle("hidden");
    closeToggle?.classList.toggle("hidden");
  });

  // Cerrar menú mobile al tocar un link
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (window.innerWidth < 768) {
        menu?.classList.add("hidden");
        menu?.classList.remove("flex");
        toggle?.classList.remove("hidden");
        closeToggle?.classList.add("hidden");
      }
    });
  });

</script>