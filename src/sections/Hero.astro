---
import IconGitHub from "@/icons/IconGitHub.astro";
import IconWhatsapp from "@/icons/IconWhatsapp.astro";
import Linkedin from "@/icons/linkedin.astro";

// src/components/HeroSection.astro
---

<main id="hero" class="w-full max-w-7xl md:mx-auto py-6 text-white scroll-mt-20">
  <section class="text-white flex flex-col justify-center items-center gap-10">
    <div class="flex items-center gap-3">
      <span class="inline-block w-6 h-px bg-sky-400" />
      <span class="font-mono text-[1.7rem] tracking-[0.2em] uppercase text-sky-400">sobre mí</span>
    </div>
    <h1 class="text-xl md:text-2xl font-medium typewriter-container">
      <span id="typewriter-text" class="typewriter-text">👋 Hola Soy Gabriel Agüero</span>
    </h1>
    <p class="text-slate-400 text-base leading-[1.85] max-w-md text-center">
        Soy un apasionado por la tecnología y la programación.<br />
        <span class="text-white/90 font-medium">Me especializo en desarrollo frontend y 
        también en soluciones digitales para el sector salud.</span> <br /> 
        Siempre con el mismo objetivo: Que la tecnología sea <span class="text-white/90 font-medium">simple, rápida, útil</span>
        y resuelva un problema real de las personas.
    </p>      

    <!-- Chips -->
    <div class="flex flex-wrap gap-2">
      {[
        'Frontend Developer',
        'Informático en Salud',        
      ].map((chip) => (
        <span class="text-[0.65rem] font-mono px-3 py-1 rounded-full border border-white/[0.08] bg-white/[0.03] text-slate-400">
          {chip}
        </span>
      ))}
    </div>

    <!-- WhatsApp CTA -->
    <div class="flex flex-col md:flex-row gap-4 items-center">
       
      <a
        href="https://wa.me/5491139392570"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2.5 text-sm font-mono px-5 py-2.5 rounded-full border border-green-500/40 bg-green-500/10 text-green-400 hover:bg-green-500/20 hover:border-green-500/60 transition-all duration-300"
      >
        <IconWhatsapp class="w-5 h-5 shrink-0" />
        Contáctame
      </a>     
      <a
        href="https://www.linkedin.com/in/gabrielhaguero/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2.5 text-sm font-mono w-full px-5 py-2.5 rounded-full border border-blue-500/40 bg-blue-500/10 text-blue-400 hover:bg-blue-500/20 hover:border-blue-500/60 transition-all duration-300"
      >
        <Linkedin class="w-5 h-5 shrink-0" />
        Linkedin
      </a>

      <a
        href="https://github.com/Gabriel-Aguero"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2.5 text-sm font-mono w-full px-5 py-2.5 rounded-full border border-slate-500/40 bg-slate-500/10 text-slate-400 hover:bg-slate-500/20 hover:border-slate-500/60 transition-all duration-300"
      >
        <IconGitHub class="w-5 h-5 shrink-0" />
        GitHub
      </a>
    </div>

  </section>
</main>

<style>
  .typewriter-container {
    position: relative;
    display: inline-block;
  }

  .typewriter-text {
    display: inline-block;
    overflow: hidden;
    border-right: 3px solid #fff;
    white-space: nowrap;
    animation: 
      typing 2s steps(22, end) forwards,
      blink 0.8s step-end infinite;
    width: 0;
    max-width: fit-content;
  }

  @keyframes typing {
    from { width: 0; }
    to { width: 100%; }
  }

  @keyframes blink {
    from, to { border-color: transparent; }
    50% { border-color: #fff; }
  }

  .animate-flash {
    animation: fadeIn 1s ease-in-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const typewriterElement = document.getElementById('typewriter-text');
    if(typewriterElement) {
      typewriterElement.style.animation = 'none';
      typewriterElement.offsetHeight;
      typewriterElement.style.animation = 'typing 2s steps(22, end) forwards, blink 0.8s step-end infinite';
      setTimeout(() => {
        typewriterElement.style.animation = 'typing 2s steps(22, end) forwards, blink 0.8s step-end infinite';
      }, 100);      
    } 
  });
</script>